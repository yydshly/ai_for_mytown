# 复制为 .env 并填入真实值；.env 不要提交（已在 .gitignore 习惯里，请自行确认）。
# 这些环境变量会被 config.example.json 里的 ${VAR} 占位自动读取。

# 文字 + 拍照诊断（MiniMax）
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# 语音朗读（MiMo Token Plan，key 以 tp- 开头）
MIMO_API_KEY=

# 天气预警（和风天气，免费档够用）
QWEATHER_API_KEY=

# 主动推送（方糖 Server酱，父母关注服务号后取 SendKey）
SERVERCHAN_KEY=
